# Archivos de variables de entorno
# Nunca rastrear archivos de configuración sensibles. El fichero `.env`
# contiene tokens y claves privadas y debe permanecer fuera del control de versiones.
.env
.env.*
*.env

# Módulos de Node
node_modules/

# Logs y archivos temporales
*.log
logs/
npm-debug.log*
yarn-debug.log*
yarn-error.log*
coverage/

# Salida de compilación
dist/
build/
.tmp/
cache/
*.tmp

# Archivos de sistema
.DS_Store
Thumbs.db

# Ajustes del editor
.vscode/
.idea/

# Archivos internos de Railway / Vercel
.vercel/
.railway/
*.sqlite
*.db

# Copias de seguridad y carpetas de pruebas
test/
backup/
*.bak

# Archivos de bloqueo (opcional)
package-lock.json
yarn.lock
pnpm-lock.yaml
