## Configuración personalizada para CryBot‑Telegram

# --- Telegram ---
# Token del bot de Telegram (proporcionado por BotFather)
BOT_TOKEN=
# ID de Telegram del administrador que podrá ejecutar comandos sensibles
ADMIN_TELEGRAM_ID=

# --- Claves privadas y RPCs ---
# Clave privada EVM de la wallet principal (no compartir; se queda en el host local)
PRIVATE_KEY=
# Clave privada para operaciones en Polygon (opcional)
POLYGON_PRIVATE_KEY=
# RPC de Polygon (por defecto a un nodo público de Polygon)
POLYGON_RPC_URL=https://polygon-rpc.com
# RPC de Ethereum para operaciones generales
RPC_URL=https://eth.llamarpc.com

# --- Wallets ---
# Lista de wallets EVM separadas por comas. Aquí añadimos la wallet de Bitget Wallet
EVM_WALLET=0x7B9Fc90C99b2ae4711BDEe31049c357999e79B09
# Dirección principal donde se recibirán los fondos de las ventas automáticas
MAIN_WALLET=0x82219fc3B1d22f0DAd2703101724dfA8f08DC456
# Otras cadenas (dejar en blanco si no se usan)
TON_WALLET=
POLYGON_WALLET=
BSC_WALLET=
SOLANA_WALLET=
APTOS_WALLET=

# --- APIs externas ---
# Claves de API opcionales para mejorar la funcionalidad
ETHERSCAN_API_KEY=
TON_API_KEY=
OPENSEA_API_BASE=https://api.opensea.io/api/v2
LOOKSRARE_API_BASE=https://api.looksrare.org/api/v2
BLUR_API_BASE=https://core-api.blur.io/v1
TON_API_BASE=https://tonapi.io/v2

# --- GetGems (TON) ---
# Parámetros para listar NFTs de TON (opcional)
GETGEMS_MARKETPLACE_ADDRESS=
GETGEMS_FEE_ADDRESS=
GETGEMS_DESTINATION_ADDRESS=
GETGEMS_ROYALTY_ADDRESS=
GETGEMS_DEFAULT_PRICE=5
GETGEMS_LIST_INTERVAL=60

# --- Planet IX (Polygon/Base) ---
# Parámetros para listar NFTs en Planet IX (opcional)
PLANETIX_MARKETPLACE_ADDRESS=
PLANETIX_COLLECTION_ADDRESS=
PLANETIX_ABI=
PLANETIX_POLL_MINUTES=5

# --- Tesorería ---
# Objetivos de distribución de activos
TREASURY_TARGET_STABLE=0.6
TREASURY_TARGET_NATIVE=0.3
TREASURY_TARGET_BETA=0.1
# Mínimos de gas
GAS_MINIMUM_ETH=0.02
GAS_MINIMUM_TON=0.30

# --- Pricing (venta automática NFTs) ---
# Diferencia porcentual respecto al floor para listar NFTs (ej. 2 significa listar a 2% por debajo del floor)
FLOOR_FOLLOW_DELTA_PCT=2
# Multiplicador mínimo para aceptar ofertas automáticamente (0.95 = 95% del floor)
ACCEPT_OFFER_FLOOR_MULTIPLIER=0.95

## Fin del archivo