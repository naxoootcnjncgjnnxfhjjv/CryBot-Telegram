## Ejemplo de archivo de variables de entorno para CryBot-Telegram

# ——— Telegram ———
BOT_TOKEN=
ADMIN_TELEGRAM_ID=

# ——— Claves privadas y RPCs ———
# Clave EVM para realizar transacciones (Ethereum)
PRIVATE_KEY=
# Clave Polygon para PlanetIX (MATIC/Base)
POLYGON_PRIVATE_KEY=
POLYGON_RPC_URL=https://polygon-rpc.com
# RPC para Ethereum principal
RPC_URL=https://eth.llamarpc.com
# RPC opcionales
BSC_RPC_URL=https://bsc-dataseed.binance.org

# ——— Wallets ———
# Listado de direcciones EVM separadas por coma
EVM_WALLET=
# Listado de direcciones TON (formato base64) separadas por coma
TON_WALLET=
# Semilla TON (24 palabras) para listar NFTs en GetGems
TON_WALLET_SEED=
# Wallets para otras cadenas (opcional)
POLYGON_WALLET=
BSC_WALLET=
SOLANA_WALLET=
APTOS_WALLET=

# ——— APIs externas ———
ETHERSCAN_API_KEY=
TON_API_KEY=
OPENSEA_API_BASE=https://api.opensea.io/api/v2
LOOKSRARE_API_BASE=https://api.looksrare.org/api/v2
BLUR_API_BASE=https://core-api.blur.io/v1
TON_API_BASE=https://tonapi.io/v2

# ——— GetGems (TON) ———
# Dirección del marketplace de GetGems para la venta v3
GETGEMS_MARKETPLACE_ADDRESS=
# Dirección donde se envían las fees de marketplace
GETGEMS_FEE_ADDRESS=
# Dirección del deployer/destination para el contrato de venta
GETGEMS_DESTINATION_ADDRESS=
# Dirección donde se pagan las royalties (puede ser tu wallet)
GETGEMS_ROYALTY_ADDRESS=
# Precio por defecto en TON para listar NFTs (ej. 5)
GETGEMS_DEFAULT_PRICE=5
# Intervalo en minutos entre listados automáticos
GETGEMS_LIST_INTERVAL=60

# ——— Planet IX (Polygon/Base) ———
PLANETIX_MARKETPLACE_ADDRESS=
PLANETIX_COLLECTION_ADDRESS=
# ABI opcional del contrato marketplace en JSON (cadena)
PLANETIX_ABI=
# Intervalo en minutos entre chequeos de ofertas
PLANETIX_POLL_MINUTES=5

# ——— Tesorería ———
# Porcentajes objetivo para la distribución de activos
TREASURY_TARGET_STABLE=0.6
TREASURY_TARGET_NATIVE=0.3
TREASURY_TARGET_BETA=0.1
# Mínimos de gas en cada cadena
GAS_MINIMUM_ETH=0.02
GAS_MINIMUM_TON=0.30

## Fin del archivo
