# CryBot Runtime
# Copiar este archivo como .env SOLO en Railway/local.
# No subir .env real a GitHub.
NODE_ENV=production
PORT=3000
BASE_URL=
WEBHOOK_PATH=/webhook

# Telegram
# Crear token nuevo en BotFather si el anterior es antiguo o fue expuesto.
# Usar TELEGRAM_BOT_TOKEN o BOT_TOKEN. La config acepta ambos.
TELEGRAM_BOT_TOKEN=
BOT_TOKEN=
ADMIN_TELEGRAM_ID=

# Blockchain APIs
TONAPI_KEY=
TON_API_KEY=
ETHERSCAN_API_KEY=
RPC_URL=https://ethereum.publicnode.com

# Destination wallet
MAIN_WALLET=
DESTINATION_WALLET=

# Wallet lists comma-separated
# TON_WALLETS debe incluir solo wallets controladas/confirmadas.
# Prioridad segura:
# - UQChtGxrxo1H74kGde0GNsSKWYG_rhGMKNco-opmWQ1B-yil  wallet central
# - UQDXGQp2nDtUb985loKLV-AK8q0qyGK9D0vixyUUd4aWVvLE  valor USDT TON
# TON_BCM / UQBCmTw... solo lectura hasta confirmar control real.
TON_WALLETS=
EVM_WALLETS=
APTOS_WALLETS=

# Runtime flags
# Mantener así mientras se audita: lectura sin ventas ni firmas.
DRY_RUN=true
ENABLE_WRITE_ACTIONS=false
SCAN_INTERVAL_MS=300000

# Venta / escritura
# No activar hasta tener inventario completo, precios reales y confirmación manual.
# ENABLE_WRITE_ACTIONS=true
# DRY_RUN=false
